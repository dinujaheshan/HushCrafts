rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helpers
    function isAuthenticated() {
      return request.auth != null;
    }
    function getAdmin() {
      return get(/databases/$(database)/documents/admins/$(request.auth.uid)).data;
    }
    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    function hasPermission(permission) {
      return isAdmin() && (getAdmin().role == 'super_admin' || getAdmin().permissions.get(permission, false) == true);
    }

    // users
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin() && hasPermission('customerUpdate');
    }

    // roles
    match /roles/{roleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && hasPermission('manageAdmins');
    }

    // permissions
    match /permissions/{permissionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && hasPermission('manageAdmins');
    }

    // user_roles
    match /user_roles/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin() && hasPermission('manageAdmins');
    }

    // products
    match /products/{productId} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow write: if isAdmin() && (hasPermission('productCreate') || hasPermission('productUpdate') || hasPermission('productDelete'));
      
      // subcollection variants
      match /variants/{variantId} {
        allow read: if true; // variants are readable if public can see them
        allow write: if isAdmin() && (hasPermission('productCreate') || hasPermission('productUpdate'));
      }
    }

    // categories
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin() && (hasPermission('categoryCreate') || hasPermission('categoryUpdate') || hasPermission('categoryDelete'));
    }

    // inventory
    match /inventory/{sku} {
      allow read: if isAdmin();
      allow write: if isAdmin() && hasPermission('inventoryUpdate');
    }

    // orders
    match /orders/{orderId} {
      allow read: if isAdmin() || (isAuthenticated() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.uid == request.auth.uid ||
        (resource.data.customerDetails != null && resource.data.customerDetails.email == request.auth.token.email)
      ));
      allow create: if true; // Anonymous guest checkouts permitted
      allow update: if isAdmin() && hasPermission('orderUpdate');
      allow delete: if isAdmin() && hasPermission('orderDelete');
      
      match /items/{itemId} {
        allow read: if isAdmin() || (isAuthenticated() && get(/databases/$(database)/documents/orders/$(orderId)).data.customerId == request.auth.uid);
        allow write: if isAdmin() && hasPermission('orderUpdate');
      }
    }

    // customers
    match /customers/{customerId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == customerId);
      allow create: if true; // customers can register or be created on guest checkout
      allow update: if isAdmin() && hasPermission('customerUpdate');
      allow delete: if isAdmin() && hasPermission('customerDelete');

      match /addresses/{addressId} {
        allow read, write: if isAdmin() || (isAuthenticated() && request.auth.uid == customerId);
      }
    }

    // wishlists
    match /users/{userId}/wishlists/{productId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // cart
    match /users/{userId}/cart/{variantId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // reviews
    match /reviews/{reviewId} {
      allow read: if resource.data.isApproved == true || isAdmin();
      allow create: if true; // customers can write reviews
      allow update: if isAdmin() && hasPermission('feedbackApprove');
      allow delete: if isAdmin() && hasPermission('feedbackDelete');
    }

    // contact_messages
    match /contact_messages/{msgId} {
      allow read: if isAdmin();
      allow create: if true; // guests can send messages
      allow update: if isAdmin() && hasPermission('messageReply');
      allow delete: if isAdmin() && hasPermission('messageDelete');
    }

    // client_notifications
    match /client_notifications/{notifId} {
      allow read: if true;
      allow create: if isAdmin() && hasPermission('messageReply');
      allow update, delete: if true;
    }

    // coupons
    match /coupons/{couponId} {
      allow read: if true; // public can read coupons to validate them on frontend
      allow write: if isAdmin() && hasPermission('settings.update');
    }

    // notifications
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (resource.data.recipientId == request.auth.uid || resource.data.recipientId == 'admin' && isAdmin());
      allow write: if isAdmin();
    }

    // logs and settings
    match /email_logs/{logId} {
      allow read, write: if isAdmin();
    }
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Audit logs should never be modified once written by functions
    }
    match /analytics_events/{eventId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if false;
    }
    match /settings/{settingsId} {
      allow read: if true; // store settings (like shipping rates) are read publically
      allow write: if isAdmin() && hasPermission('settings.update');
    }
    match /media_library/{mediaId} {
      allow read: if true;
      allow write: if isAdmin() && hasPermission('productCreate');
    }
  }
}
